APP_ENV=dev
APP_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5433/restaurant
APP_REDIS_URL=redis://localhost:6380/0
APP_JWT_SECRET=change-me-in-prod
APP_LLM_PROVIDER=fake
APP_ANTHROPIC_API_KEY=
APP_UPLOAD_DIR=var/uploads
APP_CLAUDE_MODEL=claude-opus-4-8
APP_WHATSAPP_PROVIDER=mock
APP_WA_VERIFY_TOKEN=dev-verify-token
APP_WA_ACCESS_TOKEN=
APP_WA_PHONE_NUMBER_ID=
APP_WA_APP_SECRET=
APP_WA_BUSINESS_ACCOUNT_ID=
# System-user token with catalog_management — reads/pushes Meta Commerce catalogues
# (OPS "Sync both ways"). Separate from APP_WA_ACCESS_TOKEN (messaging only).
APP_WA_CATALOG_TOKEN=
# Placeholder image URL for dishes pushed without photos (Meta requires image_link).
APP_CATALOG_PLACEHOLDER_IMAGE_URL=https://placehold.co/500x500/png?text=Menu
APP_MARKETING_SEND_DRY_RUN=true
APP_MARKETING_TEMPLATE_PROVIDER=mock
APP_WA_APP_ID=  # Facebook App ID for resumable uploads of daily template IMAGE headers (Meta /uploads)
APP_GRAPH_API_VERSION=v21.0
APP_MARKETING_EPHEMERAL_DELETE_HOUR=23
APP_MARKETING_EPHEMERAL_DELETE_MINUTE=30
APP_MARKETING_TEMPLATE_POLL_MINUTES=2
APP_GEO_PROVIDER=fake
APP_GOOGLE_MAPS_API_KEY=
APP_FORECAST_PROVIDER=rolling
# APP_SENTRY_DSN=https://...@sentry.io/...
