.venv/
__pycache__/
*.pyc
.env
var/
.pytest_cache/
.ruff_cache/
dist/
*.egg-info/

# frontend
frontend/node_modules/
frontend/dist/
frontend/node_modules/.tmp/
frontend/*.tsbuildinfo

# credentials / local access notes
ACCESS.md

# local tool state
.superpowers/

# graphify run metadata (not useful to team)
graphify-out/cost.json

# Python build artifacts
build/
*.egg-info/
# ...except the Electron app's icon source assets (desktop/build/ is
# electron-builder's buildResources dir, not a Python build artifact).
!desktop/build/
!desktop/build/*

# Firebase service-account key (FCM) — never commit
*firebase-adminsdk*.json
google-services.json

# Stray root npm artifacts (no root package.json — frontend has its own)
/node_modules/
/package-lock.json

# Local demo / test helper scripts (not part of the app)
scripts/demo_*.py
frontend/understanding.txt
terminals/
releases/
