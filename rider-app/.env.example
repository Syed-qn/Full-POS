# Copy to rider-app/.env for local `eas build --local` or `expo run:android`.
# On EAS cloud builds, set the same names as project secrets instead.

# Required for in-app map tiles (enable "Maps SDK for Android" on this key in GCP).
APP_MAPS_SDK_ANDROID=

# Optional fallback — same key as backend APP_GOOGLE_MAPS_API_KEY if Maps SDK is enabled.
# APP_GOOGLE_MAPS_API_KEY=